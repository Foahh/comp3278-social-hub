{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "sortTailwindcss": {
    "stylesheet": "src/index.css",
    "functions": ["cn", "cva"]
  },
  "sortPackageJson": true,
  "ignorePatterns": [
    "node_modules/",
    "coverage/",
    ".pnpm-store/",
    "pnpm-lock.yaml",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "bun.lock",
    "**/routeTree.gen.ts",
    "src/lib/api/schema.d.ts"
  ]
}
